---
interface Props {
  items?: Array<{ title: string; href: string; icon: string; description?: string }>;
  calculators?: Array<{ label: string; href: string; icon: string }>;
}
const { items, calculators } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const entries = items
  ? items.map(i => ({ title: i.title, href: i.href, icon: i.icon }))
  : (calculators ?? []).map(c => ({ title: c.label, href: c.href, icon: c.icon }));
---

<div class="bg-white border border-slate-200 rounded-xl overflow-hidden">
  <div class="px-5 py-4 border-b border-slate-100">
    <h3 class="font-bold text-navy-900 text-sm">Related Calculators</h3>
  </div>
  <ul class="divide-y divide-slate-100">
    {entries.map(item => (
      <li>
        <a href={`${base}${item.href}`} class="flex items-center gap-3 px-5 py-3.5 hover:bg-slate-50 transition-colors group">
          <span class="text-xl">{item.icon}</span>
          <div class="min-w-0">
            <p class="text-sm font-semibold text-navy-800 group-hover:text-brand-600 transition-colors truncate">{item.title}</p>
          </div>
          <svg class="ml-auto text-slate-300 flex-shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </a>
      </li>
    ))}
  </ul>
</div>
