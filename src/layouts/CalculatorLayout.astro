---
import BaseLayout from './BaseLayout.astro';
import RelatedCalculators from '../components/RelatedCalculators.astro';
import FAQ from '../components/FAQ.astro';

interface FAQItem {
  q: string;
  a: string;
}

interface RelatedCalc {
  title: string;
  href: string;
  icon: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  heading: string;
  subheading: string;
  icon: string;
  category?: string;
  breadcrumb?: string;
  faqs?: FAQItem[];
  related?: RelatedCalc[];
  schema?: Record<string, unknown>;
}

const { title, description, heading, subheading, icon, category, breadcrumb, faqs = [], related = [], schema } = Astro.props;
const breadcrumbLabel = breadcrumb ?? category ?? heading;
---

<BaseLayout title={title} description={description}>
  <!-- Breadcrumb -->
  <div class="bg-white border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-sm text-slate-500">
        <a href="/" class="hover:text-brand-600 transition-colors">Home</a>
        <span>›</span>
        <a href="/" class="hover:text-brand-600 transition-colors">{breadcrumbLabel}</a>
        <span>›</span>
        <span class="text-navy-900 font-medium">{heading}</span>
      </nav>
    </div>
  </div>

  <!-- Page header -->
  <div class="bg-white border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex items-start gap-4">
        <div class="w-14 h-14 bg-brand-50 rounded-2xl flex items-center justify-center text-3xl flex-shrink-0 border border-brand-100">
          {icon}
        </div>
        <div>
          <h1 class="text-2xl sm:text-3xl font-extrabold text-navy-900">{heading}</h1>
          <p class="text-slate-500 mt-1.5 text-base max-w-2xl">{subheading}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Main content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Left: calculator + content -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Calculator slot -->
        <slot name="calculator" />
        <!-- SEO content slot -->
        <div class="prose-content">
          <slot name="content" />
        </div>
        <!-- FAQ (prop-based for old pages, slot-based for new pages) -->
        {faqs.length > 0 && <FAQ items={faqs} />}
        <slot name="faq" />
      </div>
      <!-- Right: sidebar -->
      <div class="space-y-6">
        <slot name="sidebar" />
        {related.length > 0 && <RelatedCalculators items={related} />}
        <!-- Quick tips card -->
        <div class="bg-brand-50 border border-brand-100 rounded-xl p-5">
          <h3 class="font-bold text-navy-900 text-sm mb-3 flex items-center gap-2">
            <span>💡</span> Pro Tips
          </h3>
          <slot name="tips">
            <p class="text-slate-600 text-sm leading-relaxed">Always add 10% extra to material estimates to account for waste, cuts, and mistakes.</p>
          </slot>
        </div>
      </div>
    </div>
  </div>

  <!-- JSON-LD schema -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</BaseLayout>
